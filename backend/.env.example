# ================================
# Docker镜像配置 - Docker Hub 示例
# 不用docker部署可以忽略
# ================================
# Docker Hub 配置 (留空或使用 docker.io)
DOCKER_REGISTRY=https://hub.docker.com/
DOCKER_NAMESPACE=your-namespace
IMAGE_VERSION=latest

# ================================
# 服务端口配置,不用docker部署可以忽略
# ================================
# 前端服务端口
FRONTEND_PORT=80
# 后端服务端口
BACKEND_PORT=8000
# 容器内部访问MySQL的端口（Docker网络内部通信）
DB_INTERNAL_PORT=3306

# ================================
# Django配置
# ================================
# Django密钥（生产环境请使用强密钥）
SECRET_KEY=your-secret-key-here-change-in-production
# 调试模式（生产环境请设为False）
DEBUG=True
# 允许的主机列表（生产环境请指定具体域名）
ALLOWED_HOSTS=*
# 允许的跨域来源（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# 是否通过 HTTPS 访问 Django（影响 CSRF/Session Secure Cookie 默认值）
APP_USE_HTTPS=False
# 当 Nginx/网关设置了 X-Forwarded-Proto 时，是否信任该请求头
TRUST_PROXY_SSL_HEADER=False
# Django 可信来源（Admin 登录、表单提交等需要；多个用逗号分隔）
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1,http://localhost
# 如需精细控制，可单独覆盖以下 Cookie 策略
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SAMESITE=Lax

# ================================
# 数据库配置
# ================================
# 数据库主机
DB_HOST=localhost
# 数据库名称
DB_NAME=zxtest
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=your-database-password
# MySQL数据库端口号
DB_PORT=3306

# ================================
# Redis配置（可选,用于APP自动化）
# ================================
REDIS_URL=redis://127.0.0.1:6379/0

# ================================
# 阿里云短信配置
# ================================
SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
SMS_SIGN_NAME=XXXXXX
SMS_REGISTER_TEMPLATE_CODE=XXXXXX

# ================================
# 邮件配置（可选,用于定时任务通知）
# ================================
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# 日志配置
# LOG_LEVEL=INFO
# LOG_FILE=/app/logs/app.log

# 本地化配置
# 语言: 'en-us' (英语), 'zh-hans' (简体中文), 'ja' (日语), 'ko' (韩语) 等
# 时区: 参考 https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LANGUAGE_CODE=zh-hans
TIME_ZONE=Asia/Shanghai

# ================================
# 生产环境注意事项
# ================================
# 1. 请务必修改SECRET_KEY为强密钥
# 2. 设置DEBUG=False
# 3. 在ALLOWED_HOSTS中指定具体域名，不要使用*
# 4. 在CORS_ALLOWED_ORIGINS中指定具体的前端域名
# 5. 使用环境变量管理敏感信息，不要提交到版本控制
# 6. 确保数据库密码足够强壮
# 7. 邮件配置使用真实的SMTP服务
